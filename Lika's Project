  {ctx:"את בחדר כושר ומבקשת עזרה",hint:"Ask the trainer for help",txt:"Could you show me how to use this machine?"},
  {ctx:"המאמנת שלך שואלת על התזונה שלך",hint:"Describe your diet",txt:"I usually eat a balanced diet with lots of protein and vegetables."},
  {ctx:"את בתחרות התעמלות אומנותית ומדברת עם שופטת",hint:"Be formal and polite",txt:"Thank you for the feedback. I will work on improving my ribbon technique."},
  {ctx:"את בקניון ומחפשת מתנה",hint:"Ask for a recommendation",txt:"I'm looking for a birthday gift for my friend. What would you recommend?"},
