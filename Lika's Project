];
let spi=0,recog=null,isRec=false;
function initVo(){spi=Math.floor(Math.random()*SCEN.length);showScen();setVMode('scenario')}
function showScen(){
  const s=SCEN[spi];
  document.getElementById('scenDesc').textContent=s.ctx;
  document.getElementById('scenHint').textContent='💡 '+s.hint;
  document.getElementById('vPr').textContent=s.txt;
  ['vRs','vSc','vNx'].forEach(id=>{const e=document.getElementById(id);e.style.display='none';if(id==='vSc')e.textContent=''});
  document.getElementById('mSt').textContent='לחצי על המיקרופון ודברי';
}
function setVMode(m){
  document.querySelectorAll('#voiceMode .toggle-btn').forEach(b=>b.classList.remove('act'));
  event.target.classList.add('act');
  document.getElementById('scenarioPanel').style.display=m==='scenario'?'block':'none';
  document.getElementById('freePanel').style.display=m==='free'?'block':'none';
}
function tRec(){
  if(!('webkitSpeechRecognition' in window)&&!('SpeechRecognition' in window)){alert('נסי Chrome.');return;}
  if(isRec){recog&&recog.stop();return;}
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  recog=new SR();recog.lang='en-US';recog.interimResults=false;
  recog.onstart=()=>{isRec=true;document.getElementById('mBtn').classList.add('rec');document.getElementById('mSt').textContent='...מקשיבה 🎧'};
  recog.onresult=e=>procVR(e.results[0][0].transcript);
  recog.onerror=e=>{isRec=false;document.getElementById('mBtn').classList.remove('rec');document.getElementById('mSt').textContent=e.error==='no-speech'?'לא שמעתי, נסי שוב':'שגיאה'};
  recog.onend=()=>{isRec=false;document.getElementById('mBtn').classList.remove('rec')};
  recog.start();
}
function procVR(tr){
  const target=SCEN[spi].txt.toLowerCase().replace(/[^a-z\s]/g,''),spoken=tr.toLowerCase().replace(/[^a-z\s]/g,'');
  const tw=target.split(/\s+/),sw=spoken.split(/\s+/);
  let m=0,j=0;for(let i=0;i<tw.length&&j<sw.length;i++){if(tw[i]===sw[j]){m++;j++}else{const n=sw.indexOf(tw[i],j);if(n!==-1&&n-j<3){m++;j=n+1}}}
  const acc=Math.round(m/tw.length*100);
  document.getElementById('vRs').style.display='block';document.getElementById('vRs').innerHTML=`<strong style="color:var(--g400)">You said:</strong> "${tr}"`;
  const s=document.getElementById('vSc');s.style.display='block';s.textContent=acc+'%';s.style.color=acc>=80?'var(--grn)':acc>=50?'var(--goldd)':'var(--b7)';
  document.getElementById('mSt').textContent=acc>=80?'!מצוין 🌟':acc>=50?'לא רע! 💪':'נסי שוב 📢';
  document.getElementById('vNx').style.display='inline-block';
  if(acc>=60){D.xp+=5;D.dd++;sv();updUI()}
}
function nVP(){spi=(spi+1)%SCEN.length;showScen()}

/* ═══════════════════════════════════════════
   FREE CHAT (AI-powered)
   Uses Anthropic API — works in Claude.ai preview.
   For GitHub Pages: add API key in the prompt below.
   The bot converses and rates grammar 1-10.
   ═══════════════════════════════════════════ */
let chatLv=40,fbFreq='every',chatHist=[],chatMsgCount=0;
function setChatLv(lv){chatLv=lv;document.querySelectorAll('#chatLvlRow .toggle-btn').forEach(b=>b.classList.remove('act'));event.target.classList.add('act')}
function setFbFreq(f){fbFreq=f;document.getElementById('fbEvery').classList.toggle('act',f==='every');document.getElementById('fbFew').classList.toggle('act',f==='few')}

function addChatMsg(text,cls){
  const log=document.getElementById('chatLog'),d=document.createElement('div');
  d.className='chat-msg '+cls;d.textContent=text;log.appendChild(d);log.scrollTop=log.scrollHeight;
}

async function sendChat(){
  const inp=document.getElementById('chatIn'),txt=inp.value.trim();if(!txt)return;
  inp.value='';addChatMsg(txt,'user');chatHist.push({role:'user',content:txt});chatMsgCount++;

  const shouldEval=fbFreq==='every'||(chatMsgCount%2===0);
  const lvDesc={20:'very simple vocabulary, short sentences, basic grammar',40:'simple everyday English, common expressions',60:'intermediate English with some complex grammar',80:'advanced English with idioms and complex structures',100:'sophisticated academic English, nuanced vocabulary'};
  const sysPrompt=`You are a friendly English conversation partner for Lika who is learning English. 
Conversation difficulty level: ${chatLv}/100 (${lvDesc[chatLv]||lvDesc[40]}).
Adjust YOUR vocabulary and grammar complexity to match level ${chatLv}.
Keep responses SHORT (1-3 sentences max).
Topics: daily life, shopping, fitness, rhythmic gymnastics, travel, nutrition.
${shouldEval?`IMPORTANT: After your conversational response, add on a NEW LINE:
[SCORE: X/10] followed by brief feedback on her grammar/vocabulary/appropriateness. Be encouraging but honest. Rate the user's last message from 1 (poor) to 10 (excellent) for grammar correctness and contextual appropriateness. This is a FREE TEXT conversation — rate how well what she said fits grammatically and contextually.`:'Just respond conversationally, no scoring this turn.'}`;

  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:300,system:sysPrompt,messages:chatHist})});
    const data=await res.json();
    const full=data.content.map(c=>c.text||'').join('');
    chatHist.push({role:'assistant',content:full});

    // Split response and score
    const scoreMatch=full.match(/\[SCORE:\s*(\d+)\/10\]\s*(.*)/s);
    if(scoreMatch){
      const convPart=full.substring(0,full.indexOf('[SCORE:')).trim();
      addChatMsg(convPart,'bot');
      addChatMsg(`📊 ${scoreMatch[1]}/10 — ${scoreMatch[2].trim()}`,'eval');
    } else {
      addChatMsg(full,'bot');
    }
  }catch(e){
    addChatMsg("I'm having trouble connecting. Try typing your response and I'll do my best! 😊",'bot');
    // Fallback: simple echo-back for offline/GitHub Pages
    if(shouldEval){addChatMsg(`📊 Keep practicing! The AI scoring works best in Claude.ai preview.`,'eval')}
  }
}

