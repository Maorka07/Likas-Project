  if(q.p)h+=`<div class="psg">${q.p}</div>`;
  const txt=q.q||q.t;
  h+=`<div class="qt2">${qt==='comp'?txt.replace('_____','<span class="bl">&nbsp;</span>'):txt}</div>`;
  h+='<div class="ops">';(q.o).forEach((op,i)=>{h+=`<button class="op" onclick="selO(this,${i})" data-i="${i}"><span class="ol">${L[i]}</span><span>${op}</span></button>`;});
  h+='</div>';h+=`<button class="cb" id="cBtn" disabled onclick="confA()">אישור ✓</button></div>`;
  document.getElementById('qA').innerHTML=h;window._sel=-1;
  startTm(q.p?150:90);
}
function selO(b,i){document.querySelectorAll('.op').forEach(x=>x.classList.remove('sel'));b.classList.add('sel');window._sel=i;document.getElementById('cBtn').disabled=false}
function confA(){
  if(window._sel===-1)return;clearInterval(QZ.timer);
  const q=QZ.qs[QZ.qi],ok=window._sel===q.c;
  document.querySelectorAll('.op').forEach((b,i)=>{if(i===q.c)b.classList.add('ok');else if(i===window._sel&&!ok)b.classList.add('wr');b.classList.add('dis');});
  document.getElementById('cBtn').style.display='none';
  ok?(QZ.correct++,toast('!נכון 🎉','ok')):toast('ממשיכים 💪','no');
  QZ.total++;QZ.qi++;setTimeout(showQ,1500);
}
function exitQ(){clearInterval(QZ.timer);QZ.total>0?finishQ():nav('S_home')}
function startTm(s){QZ.tLeft=s;const T=s;updTd();clearInterval(QZ.timer);
  QZ.timer=setInterval(()=>{QZ.tLeft--;if(QZ.tLeft<=0){clearInterval(QZ.timer);toast('⏰ נגמר הזמן','no');QZ.total++;QZ.qi++;setTimeout(showQ,1200);return;}updTd();
  const p=(QZ.tLeft/T)*100,f=document.getElementById('tF');f.style.width=p+'%';f.className='tf'+(p<20?' dng':p<35?' wrn':'');
  document.getElementById('tD').className='td'+(p<20?' dng':p<35?' wrn':'');},1000);
}
function updTd(){document.getElementById('tD').textContent=Math.floor(QZ.tLeft/60)+':'+String(QZ.tLeft%60).padStart(2,'0')}
function finishQ(){
  clearInterval(QZ.timer);const pct=QZ.total?Math.round(QZ.correct/QZ.total*100):0;
  const xp=QZ.correct*10+(QZ.level>=3?QZ.correct*5:0);D.xp+=xp;D.dd++;
  const t=new Date().toDateString();if(D.ld!==t){D.str++;D.ld=t;}
  const km={comp:'lc',rest:'lr',read:'lrd',exam:'le'},k=km[QZ.type]||km[lastType];
  let nLv=D[k],msg='';
  if(pct>=75&&nLv<5){nLv++;msg=`📈 רמה מומלצת עלתה ל${LVS[nLv-1].nm}!`;}
  else if(pct<40&&nLv>1){nLv--;msg=`📉 נמליץ לחזור ל${LVS[nLv-1].nm}`;}
  else msg=`✅ רמה מומלצת: ${LVS[nLv-1].nm}`;
  D[k]=nLv;sv();updUI();
  let tr,ti;if(pct>=90){tr='🏆';ti='!מדהימה';}else if(pct>=70){tr='🌟';ti='!מצוין';}else if(pct>=50){tr='💪';ti='לא רע!';}else{tr='📚';ti='ממשיכים!';}
  document.getElementById('rC').innerHTML=`<div class="tr">${tr}</div><h2>${ti}</h2><div class="sb">${pct}%</div><div class="xp">+${xp} XP ⭐</div><div class="rb"><div class="ri"><span class="rl">נכונות</span><span class="rv">${QZ.correct}/${QZ.total}</span></div><div class="ri"><span class="rl">רמה</span><span class="rv">${LVS[QZ.level-1].nm}</span></div><div class="ri"><span class="rl">רצף</span><span class="rv">🔥 ${D.str}</span></div></div><div class="lrc">${msg}</div>`;
  document.getElementById('rRe').onclick=()=>startP(lastType,D[k]);
  nav('S_res');if(pct>=70)confetti();
}
function toast(m,t){const e=document.getElementById('tst');e.textContent=m;e.className=`tst ${t==='ok'?'tok':'tno'} sh`;setTimeout(()=>e.classList.remove('sh'),2000)}
function confetti(){const c=document.getElementById('cnf'),cols=['#3B82F6','#60A5FA','#93C5FD','#F9A8D4','#A7F3D0','#FDE68A'];for(let i=0;i<35;i++){const p=document.createElement('div');p.className='cp';p.style.left=Math.random()*100+'%';p.style.background=cols[~~(Math.random()*6)];p.style.animationDelay=Math.random()*2+'s';p.style.animationDuration=(2+Math.random()*2)+'s';p.style.borderRadius=Math.random()>.5?'50%':'2px';p.style.width=(5+Math.random()*7)+'px';p.style.height=p.style.width;c.appendChild(p)}setTimeout(()=>c.innerHTML='',5e3)}

