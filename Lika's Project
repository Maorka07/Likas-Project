let chatRecog=null,isChatRec=false;
function tRecChat(){
  if(!('webkitSpeechRecognition' in window)&&!('SpeechRecognition' in window)){alert('נסי Chrome');return}
  if(isChatRec){chatRecog&&chatRecog.stop();return}
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  chatRecog=new SR();chatRecog.lang='en-US';chatRecog.interimResults=false;
  const btn=document.getElementById('chatMic');
  chatRecog.onstart=()=>{isChatRec=true;btn.textContent='🔴';btn.style.background='var(--red)'};
  chatRecog.onresult=e=>{document.getElementById('chatIn').value=e.results[0][0].transcript;sendChat()};
  chatRecog.onend=()=>{isChatRec=false;btn.textContent='🎤';btn.style.background='var(--b6)'};
  chatRecog.onerror=()=>{isChatRec=false;btn.textContent='🎤';btn.style.background='var(--b6)'};
  chatRecog.start();
}

