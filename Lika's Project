<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lika's Project ✨</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Secular+One&family=Playfair+Display:ital,wght@0,500;0,700;1,500&display=swap" rel="stylesheet">
<style>
:root{
--b1:#EFF6FF;--b2:#DBEAFE;--b3:#BFDBFE;--b4:#93C5FD;--b5:#60A5FA;--b6:#3B82F6;--b7:#2563EB;--b8:#1D4ED8;--b9:#1E40AF;
--pink:#F9A8D4;--pkd:#EC4899;--grn:#22C55E;--grns:#BBF7D0;--red:#EF4444;--gold:#FDE68A;--goldd:#F59E0B;
--w:#FFF;--cr:#F8FAFF;--g50:#F9FAFB;--g100:#F3F4F6;--g200:#E5E7EB;--g300:#D1D5DB;--g400:#9CA3AF;--g500:#6B7280;--g600:#4B5563;--g700:#374151;--g800:#1F2937;
--sh:0 4px 14px rgba(30,64,175,.08);--shl:0 8px 30px rgba(30,64,175,.1);--shg:0 4px 20px rgba(59,130,246,.22);
--r:14px;--rl:20px;--rx:28px;--rf:9999px;--tr:.3s cubic-bezier(.4,0,.2,1);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Nunito',sans-serif;background:var(--cr);color:var(--g800);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 15% 0%,rgba(59,130,246,.05),transparent 50%),radial-gradient(ellipse at 85% 100%,rgba(249,168,212,.04),transparent 50%);pointer-events:none;z-index:0}
.heb{font-family:'Secular One','Nunito',sans-serif}
.eng{font-family:'Playfair Display',serif;direction:ltr;text-align:left}
.bgd{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.bgd .o{position:absolute;border-radius:50%;opacity:.06;animation:fl 24s ease-in-out infinite}
.bgd .o:nth-child(1){width:260px;height:260px;background:var(--b5);top:-60px;right:-40px}
.bgd .o:nth-child(2){width:160px;height:160px;background:var(--pink);bottom:10%;left:-30px;animation-delay:-7s}
.bgd .o:nth-child(3){width:100px;height:100px;background:var(--b7);top:40%;right:5%;animation-delay:-14s}
@keyframes fl{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(15px,-20px) scale(1.04)}66%{transform:translate(-10px,15px) scale(.96)}}
.app{position:relative;z-index:1;max-width:780px;margin:0 auto;padding:12px 12px 96px}
.tb{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;margin-bottom:16px;background:var(--w);border-radius:var(--rl);box-shadow:var(--sh);gap:8px;flex-wrap:wrap}
.tb .logo{display:flex;align-items:center;gap:8px;font-family:'Secular One',sans-serif;font-size:1.1rem;color:var(--b7)}
.tb .logo .ic{width:34px;height:34px;background:linear-gradient(135deg,var(--b6),var(--b8));border-radius:var(--r);display:flex;align-items:center;justify-content:center;font-size:1rem;color:#fff;box-shadow:var(--shg)}
.sts{display:flex;gap:8px;font-size:.82rem;font-weight:700}
.si{display:flex;align-items:center;gap:3px;padding:4px 9px;background:var(--b1);border-radius:var(--rf)}
.sc{display:none;animation:si .4s ease-out}.sc.on{display:block}
@keyframes si{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.motto{background:linear-gradient(135deg,var(--b6),var(--b8) 60%,var(--b9));border-radius:var(--rx);padding:28px 20px 24px;color:#fff;text-align:center;margin-bottom:18px;box-shadow:var(--shl);position:relative;overflow:hidden}
.motto::before{content:'';position:absolute;top:-40%;right:-20%;width:160px;height:160px;background:rgba(255,255,255,.1);border-radius:50%}
.motto .qt{font-family:'Playfair Display',serif;font-size:1.35rem;font-weight:700;font-style:italic;position:relative;z-index:1;text-shadow:0 2px 8px rgba(0,0,0,.12);line-height:1.5}
.motto .sub{font-size:.85rem;opacity:.85;margin-top:8px;position:relative;z-index:1}
.motto .icons{position:relative;z-index:1;margin-top:10px;font-size:1.2rem;letter-spacing:10px;opacity:.6}
.pcard{background:var(--w);border-radius:var(--rx);padding:18px;text-align:center;box-shadow:var(--sh);margin-bottom:18px}
.pcard h3{font-family:'Secular One',sans-serif;color:var(--g600);margin-bottom:10px;font-size:.9rem}
.rw{position:relative;width:110px;height:110px;margin:0 auto 6px}
.rw svg{transform:rotate(-90deg)}
.rbg{fill:none;stroke:var(--b1);stroke-width:10}.rfill{fill:none;stroke:var(--b6);stroke-width:10;stroke-linecap:round;transition:stroke-dashoffset 1s ease}
.rtxt{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:1.3rem;font-weight:900;color:var(--b7)}
.pcard .enc{font-size:.82rem;color:var(--g500);margin-top:3px}
.fg{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:18px}
.ft{background:var(--w);border-radius:var(--rl);padding:18px 10px;text-align:center;cursor:pointer;transition:var(--tr);box-shadow:0 1px 4px rgba(30,64,175,.05);border:2px solid transparent;overflow:hidden;position:relative}
.ft::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--b5);transform:scaleX(0);transition:transform .3s}
.ft:hover::before{transform:scaleX(1)}.ft:hover{transform:translateY(-3px);box-shadow:var(--sh);border-color:rgba(59,130,246,.08)}
.ft:active{transform:scale(.97)}.ft .fi{font-size:1.7rem;margin-bottom:5px}.ft .fn{font-family:'Secular One',sans-serif;font-size:.82rem;color:var(--g700);margin-bottom:2px}.ft .fd{font-size:.68rem;color:var(--g400)}
.card{background:var(--w);border-radius:var(--rx);padding:22px 18px;box-shadow:var(--sh);margin-bottom:16px}
.qh{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;gap:6px}
.qh .bk{background:var(--w);border:none;border-radius:var(--rf);width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:1rem;cursor:pointer;box-shadow:0 1px 4px rgba(0,0,0,.06);transition:var(--tr)}
.qh .bk:hover{background:var(--g50);transform:scale(1.08)}
.qh .inf{text-align:center;flex:1}
.qh .bdg{display:inline-block;padding:3px 12px;border-radius:var(--rf);font-size:.72rem;font-weight:700;background:var(--b1);color:var(--b7)}
.qh .sv{background:var(--w);border:2px solid var(--g200);border-radius:var(--rf);padding:5px 12px;font-size:.72rem;font-weight:700;cursor:pointer;transition:var(--tr);color:var(--g500);font-family:'Secular One',sans-serif}
.qh .sv:hover{border-color:var(--b5);color:var(--b6)}
.tmb{background:var(--g100);border-radius:var(--rf);height:6px;margin-bottom:16px;overflow:hidden}
.tmb .tf{height:100%;border-radius:var(--rf);background:linear-gradient(90deg,var(--b5),var(--b7));transition:width 1s linear}
.tmb .tf.wrn{background:linear-gradient(90deg,var(--goldd),var(--goldd))}.tmb .tf.dng{background:linear-gradient(90deg,var(--pkd),var(--red))}
.td{text-align:center;font-size:.78rem;font-weight:700;color:var(--g500);margin-bottom:10px;margin-top:-8px}
.td.wrn{color:var(--goldd)}.td.dng{color:var(--red);animation:pls 1s infinite}
@keyframes pls{0%,100%{opacity:1}50%{opacity:.5}}
.qc{background:var(--w);border-radius:var(--rx);padding:22px 18px;box-shadow:var(--sh);margin-bottom:14px;animation:ci .4s ease-out}
@keyframes ci{from{opacity:0;transform:translateY(14px) scale(.97)}to{opacity:1;transform:translateY(0) scale(1)}}
.qc .tp{display:inline-block;padding:3px 10px;border-radius:var(--rf);font-size:.68rem;font-weight:700;margin-bottom:8px;background:var(--b1);color:var(--b7)}
.qc .qt2{font-family:'Playfair Display',serif;font-size:1.05rem;line-height:1.7;color:var(--g800);direction:ltr;text-align:left;margin-bottom:14px}
.qc .qt2 .bl{display:inline-block;min-width:55px;border-bottom:3px dashed var(--b4);margin:0 3px}
.psg{background:var(--g50);border-radius:var(--r);padding:14px;margin-bottom:14px;border-right:4px solid var(--b5);max-height:220px;overflow-y:auto;font-family:'Playfair Display',serif;font-size:.92rem;line-height:1.8;direction:ltr;text-align:left;color:var(--g700)}
.ops{display:flex;flex-direction:column;gap:7px}
.op{display:flex;align-items:center;gap:10px;width:100%;padding:12px 13px;background:var(--g50);border:2px solid var(--g200);border-radius:var(--r);cursor:pointer;transition:var(--tr);font-family:'Playfair Display',serif;font-size:.92rem;direction:ltr;text-align:left;color:var(--g700)}
.op:hover{border-color:var(--b5);background:var(--b1);transform:translateX(3px)}
.op .ol{width:26px;height:26px;flex-shrink:0;display:flex;align-items:center;justify-content:center;border-radius:6px;background:var(--w);font-family:'Nunito',sans-serif;font-weight:800;font-size:.75rem;color:var(--g500);border:2px solid var(--g200);transition:var(--tr)}
.op:hover .ol{border-color:var(--b5);color:var(--b7)}
.op.sel{border-color:var(--b6);background:var(--b1)}.op.sel .ol{background:var(--b6);color:#fff;border-color:var(--b6)}
.op.ok{border-color:var(--grn);background:rgba(34,197,94,.07);pointer-events:none}.op.ok .ol{background:var(--grn);color:#fff;border-color:var(--grn)}
.op.wr{border-color:var(--red);background:rgba(239,68,68,.05);pointer-events:none}.op.wr .ol{background:var(--red);color:#fff;border-color:var(--red)}
.op.dis{pointer-events:none;opacity:.4}
.hint-btn{display:inline-block;padding:6px 14px;border:2px solid var(--b3);border-radius:var(--rf);background:var(--b1);color:var(--b6);font-size:.78rem;font-weight:700;cursor:pointer;margin-bottom:10px;transition:var(--tr)}
.hint-btn:hover{background:var(--b2);border-color:var(--b5)}
.hint-text{font-size:.85rem;color:var(--b7);background:var(--b1);padding:8px 12px;border-radius:var(--r);margin-bottom:10px;display:none;direction:ltr;text-align:left;font-style:italic}
.cb{display:block;width:100%;padding:13px;border:none;border-radius:var(--r);background:linear-gradient(135deg,var(--b6),var(--b8));color:#fff;font-family:'Nunito',sans-serif;font-size:.92rem;font-weight:800;cursor:pointer;margin-top:10px;box-shadow:var(--shg);transition:var(--tr)}
.cb:hover{transform:translateY(-2px)}.cb:disabled{background:var(--g300);cursor:not-allowed;box-shadow:none;transform:none}
.cb2{padding:10px 20px;border:2px solid var(--g200);border-radius:var(--rf);background:var(--w);font-family:'Nunito',sans-serif;font-weight:700;font-size:.85rem;cursor:pointer;transition:var(--tr);color:var(--g600)}
.cb2:hover{border-color:var(--b5);color:var(--b7);background:var(--b1)}
.cb2.pri{background:linear-gradient(135deg,var(--b6),var(--b8));color:#fff;border:none;box-shadow:var(--shg)}
.tst{position:fixed;bottom:100px;left:50%;transform:translateX(-50%) translateY(80px);padding:10px 22px;border-radius:var(--rf);font-weight:800;font-size:.85rem;z-index:100;opacity:0;transition:all .4s cubic-bezier(.34,1.56,.64,1);pointer-events:none;white-space:nowrap}
.tst.sh{opacity:1;transform:translateX(-50%) translateY(0)}
.tst.tok{background:var(--grn);color:#fff}.tst.tno{background:var(--b7);color:#fff}
/* Vocab card */
.fc{background:var(--w);border-radius:var(--rx);min-height:180px;display:flex;align-items:center;justify-content:center;flex-direction:column;padding:24px;box-shadow:var(--sh);margin-bottom:14px;transition:.4s ease}
.fc .wd{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;color:var(--g800);margin-bottom:4px}
.fc .ph{font-size:.82rem;color:var(--g400);margin-bottom:10px}
.fc .mn{font-family:'Secular One',sans-serif;font-size:1rem;color:var(--b7);margin-bottom:6px}
.fc .ex{font-family:'Playfair Display',serif;font-size:.88rem;font-style:italic;color:var(--g500);direction:ltr}
.fc .hp{font-size:.72rem;color:var(--g400);margin-top:10px}
.vbtn-row{display:flex;gap:8px;justify-content:center;margin-bottom:14px;flex-wrap:wrap}
.vbtn-row button{padding:9px 18px;border:2px solid var(--g200);border-radius:var(--rf);background:var(--w);font-family:'Nunito',sans-serif;font-weight:700;font-size:.82rem;cursor:pointer;transition:var(--tr);color:var(--g600)}
.vbtn-row .kn:hover{border-color:var(--grn);color:#166534;background:rgba(34,197,94,.07)}
.vbtn-row .dk:hover{border-color:var(--b6);color:var(--b7);background:var(--b1)}
.vbtn-row .rv:hover{border-color:var(--pkd);color:var(--pkd)}
.vbtn-row .nx:hover{border-color:var(--b5);color:var(--b7);background:var(--b1)}
/* Voice / Chat */
.mc{width:70px;height:70px;border-radius:50%;border:none;background:linear-gradient(135deg,var(--b5),var(--b8));color:#fff;font-size:1.6rem;cursor:pointer;box-shadow:var(--shg);transition:.5s cubic-bezier(.34,1.56,.64,1);position:relative;margin:0 auto 14px;display:flex;align-items:center;justify-content:center}
.mc:hover{transform:scale(1.1)}.mc.rec{animation:mp 1.5s ease-in-out infinite;background:linear-gradient(135deg,var(--pkd),var(--red));box-shadow:0 4px 24px rgba(236,72,153,.35)}
@keyframes mp{0%,100%{box-shadow:0 0 0 0 rgba(236,72,153,.35)}50%{box-shadow:0 0 0 16px rgba(236,72,153,0)}}
.mc .rp{position:absolute;inset:-6px;border:3px solid rgba(59,130,246,.2);border-radius:50%;animation:ro 2s ease-out infinite;pointer-events:none}
.mc.rec .rp{border-color:rgba(236,72,153,.2)}
@keyframes ro{0%{transform:scale(.8);opacity:1}100%{transform:scale(1.5);opacity:0}}
.chat-log{max-height:300px;overflow-y:auto;padding:10px;background:var(--g50);border-radius:var(--r);margin-bottom:12px;display:flex;flex-direction:column;gap:8px}
.chat-msg{padding:10px 14px;border-radius:var(--r);max-width:85%;font-size:.88rem;line-height:1.5;direction:ltr;text-align:left}
.chat-msg.bot{background:var(--b1);color:var(--g700);align-self:flex-start;border-bottom-left-radius:4px}
.chat-msg.user{background:var(--b6);color:#fff;align-self:flex-end;border-bottom-right-radius:4px}
.chat-msg.eval{background:var(--gold);color:var(--g800);align-self:flex-start;font-size:.82rem;border:1px solid var(--goldd);font-weight:600}
.chat-input{display:flex;gap:8px;margin-bottom:10px}
.chat-input input{flex:1;padding:10px 14px;border:2px solid var(--g200);border-radius:var(--rf);font-family:'Nunito',sans-serif;font-size:.88rem;direction:ltr;text-align:left}
.chat-input input:focus{outline:none;border-color:var(--b5)}
.chat-input button{padding:10px 16px;border:none;border-radius:var(--rf);background:var(--b6);color:#fff;font-weight:800;cursor:pointer;font-size:.85rem}
.lvs{background:var(--w);border-radius:var(--rx);padding:22px 16px;box-shadow:var(--sh);margin-bottom:18px}
.lvs h3{font-family:'Secular One',sans-serif;text-align:center;margin-bottom:4px;color:var(--g700);font-size:1rem}
.lvs .ld{text-align:center;font-size:.8rem;color:var(--g400);margin-bottom:12px}
.lvs .rec{text-align:center;font-size:.78rem;color:var(--b7);font-weight:700;margin-bottom:10px;padding:5px 12px;background:var(--b1);border-radius:var(--rf);display:inline-block}
.lbs{display:flex;flex-direction:column;gap:7px}
.lb{display:flex;align-items:center;gap:10px;padding:11px 13px;border:2px solid var(--g200);border-radius:var(--r);background:var(--w);cursor:pointer;transition:var(--tr);text-align:right}
.lb:hover{border-color:var(--b5);background:var(--b1);transform:translateX(-3px)}
.lb.rlv{border-color:var(--b4);background:var(--b1)}
.lb .li{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;background:var(--b2);color:var(--b7)}
.lb .ln{font-weight:800;font-size:.88rem;color:var(--g700)}.lb .ldd{font-size:.7rem;color:var(--g400)}
/* Results */
.rc{background:var(--w);border-radius:var(--rx);padding:26px 20px;text-align:center;box-shadow:var(--shl);margin-bottom:18px}
.rc .tr{font-size:3rem;margin-bottom:6px}.rc h2{font-family:'Secular One',sans-serif;font-size:1.3rem;margin-bottom:3px}
.rc .sb{font-size:2.3rem;font-weight:900;color:var(--b7);margin:6px 0}
.rc .xp{display:inline-block;padding:5px 14px;background:var(--b2);color:var(--b8);border-radius:var(--rf);font-weight:800;margin:6px 0}
.rc .lrc{margin-top:12px;padding:8px 12px;background:var(--b1);border-radius:var(--r);font-size:.82rem;color:var(--b7)}
.rb{display:flex;gap:7px;justify-content:center;margin:12px 0;flex-wrap:wrap}
.rb .ri{padding:6px 12px;background:var(--g50);border-radius:var(--r);font-size:.8rem}
.rb .ri .rl{color:var(--g400);display:block;font-size:.68rem}.rb .ri .rv{font-weight:800;color:var(--g700)}
.abr{display:flex;gap:8px;flex-wrap:wrap;justify-content:center}
/* Unknown words list */
.uw-item{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:1px solid var(--g100);gap:10px}
.uw-item:last-child{border-bottom:none}
.uw-item .uw-word{font-family:'Playfair Display',serif;font-weight:700;font-size:.95rem;color:var(--g800)}
.uw-item .uw-mean{font-size:.82rem;color:var(--g500)}
.uw-item .uw-del{background:none;border:none;color:var(--red);cursor:pointer;font-size:1rem;padding:4px 8px;border-radius:var(--rf);transition:var(--tr)}
.uw-item .uw-del:hover{background:var(--reds)}
.toggle-row{display:flex;gap:8px;justify-content:center;margin-bottom:12px;flex-wrap:wrap}
.toggle-btn{padding:6px 14px;border:2px solid var(--g200);border-radius:var(--rf);background:var(--w);font-size:.78rem;font-weight:700;cursor:pointer;transition:var(--tr);color:var(--g500)}
.toggle-btn.act{border-color:var(--b6);background:var(--b1);color:var(--b7)}
.cnf{position:fixed;inset:0;pointer-events:none;z-index:200;overflow:hidden}
.cp{position:absolute;top:-20px;animation:cf 3s ease-in forwards}
@keyframes cf{0%{transform:translateY(0) rotate(0);opacity:1}100%{transform:translateY(100vh) rotate(720deg);opacity:0}}
.bn{position:fixed;bottom:0;left:0;right:0;background:var(--w);border-top:1px solid var(--g200);display:flex;justify-content:center;padding:5px 0 max(5px,env(safe-area-inset-bottom));z-index:50;box-shadow:0 -2px 8px rgba(0,0,0,.03)}
.nn{display:flex;flex-direction:column;align-items:center;padding:4px 14px;border:none;background:none;cursor:pointer;color:var(--g400);font-size:.6rem;font-weight:700;transition:var(--tr);font-family:'Secular One',sans-serif}
.nn span:first-child{font-size:1.15rem;margin-bottom:1px}.nn.ac{color:var(--b7)}.nn:hover{color:var(--b5)}
@media(max-width:600px){.app{padding:8px 8px 84px}.motto{padding:20px 12px 18px}.motto .qt{font-size:1.1rem}.fg{gap:6px}.ft{padding:14px 8px}.ft .fi{font-size:1.3rem}.ft .fn{font-size:.75rem}.qc{padding:16px 13px}.op{padding:10px 11px;font-size:.85rem}}
</style>
</head>
<body>
<div class="bgd"><div class="o"></div><div class="o"></div><div class="o"></div></div>
<div id="tst" class="tst"></div>
<div id="cnf" class="cnf"></div>
<div class="app">
<header class="tb">
  <div class="logo"><div class="ic">✨</div><span>Lika's Project</span></div>
  <div class="sts"><div class="si">🔥<span id="sStr">0</span></div><div class="si">⭐<span id="sXP">0</span></div><div class="si">💎<span id="sLv">1</span></div></div>
</header>

<!-- HOME -->
<section id="S_home" class="sc on">
  <div class="motto"><div class="qt" id="mottoQ"></div><div class="sub">בואי נתרגל ביחד אנגלית 🌸</div><div class="icons">🤸‍♀️ 🎀 🛍️ ✈️ 💪</div></div>
  <div class="pcard"><h3>התקדמות יומית</h3><div class="rw"><svg width="110" height="110" viewBox="0 0 110 110"><circle class="rbg" cx="55" cy="55" r="46"/><circle class="rfill" id="pR" cx="55" cy="55" r="46" stroke-dasharray="289" stroke-dashoffset="289"/></svg><div class="rtxt" id="pP">0%</div></div><div class="enc" id="enc">בואי נתחיל! ✨</div></div>
  <div class="fg">
    <div class="ft" onclick="openLvl('comp')"><span class="fi">📝</span><div class="fn">השלמת משפטים</div><div class="fd">Sentence Completions</div></div>
