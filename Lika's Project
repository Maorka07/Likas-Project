let vDir='en',vPool=[],vi=0,revealed=false;
function setVDir(d){vDir=d;document.querySelectorAll('#vDirRow .toggle-btn').forEach(b=>b.classList.remove('act'));event.target.classList.add('act');initV()}

function initV(){
  // Decrement counters for known/unknown
  for(const w in D.vKnown){D.vKnown[w]--;if(D.vKnown[w]<=0)delete D.vKnown[w]}
  for(const w in D.vUnknown){D.vUnknown[w]--;if(D.vUnknown[w]<=0)delete D.vUnknown[w]}
  sv();

  // Build pool: filter by level, exclude recently-known words
  const maxD=Math.min((D.lv||1)+1,5);
  let pool=VB.filter(v=>v.d<=maxD&&!D.vKnown[v.w]);

  // Prioritize unknown words (they come back after 8)
  const unknownDue=pool.filter(v=>D.vUnknown[v.w]!==undefined&&D.vUnknown[v.w]<=0);
  const others=pool.filter(v=>!D.vUnknown[v.w]||D.vUnknown[v.w]>0);
  // Interleave: unknown first, then others
  vPool=[...unknownDue.sort(()=>Math.random()-.5),...others.sort(()=>Math.random()-.5)];
  vi=0;revealed=false;showVC();
}
function showVC(){
  if(!vPool.length||vi>=vPool.length){toast('סיימת! 🎉','ok');vi=0;return}
  const v=vPool[vi];revealed=false;
  document.getElementById('vC').textContent=`${vi+1}/${vPool.length}`;
  // Show front side based on direction
  if(vDir==='en'){
    document.getElementById('cF').innerHTML=`<div class="wd">${v.w}</div><div class="ph">${v.ph}</div>`;
  } else {
    document.getElementById('cF').innerHTML=`<div class="mn" style="font-size:1.4rem">${v.m}</div>`;
  }
  document.getElementById('revealBtn').style.display='inline-block';
  document.getElementById('dkBtn').style.display='none';
  document.getElementById('knBtn').style.display='none';
  const fc=document.getElementById('fcd');fc.style.animation='none';fc.offsetHeight;fc.style.animation='ci .4s ease-out';
}
function revealV(){
  revealed=true;const v=vPool[vi];
  if(vDir==='en'){
    document.getElementById('cF').innerHTML=`<div class="wd">${v.w}</div><div class="ph">${v.ph}</div><div class="mn">${v.m}</div><div class="ex">"${v.ex}"</div>`;
  } else {
    document.getElementById('cF').innerHTML=`<div class="mn" style="font-size:1.4rem">${v.m}</div><div class="wd" style="margin-top:8px">${v.w}</div><div class="ph">${v.ph}</div><div class="ex">"${v.ex}"</div>`;
  }
  document.getElementById('revealBtn').style.display='none';
  document.getElementById('dkBtn').style.display='inline-block';
  document.getElementById('knBtn').style.display='inline-block';
}
function nextV(){vi++;if(vi>=vPool.length){toast('סיימת! 🎉','ok');D.dd++;sv();updUI();vi=0;}showVC()}
function vAns(knew){
  const w=vPool[vi].w;
  if(knew){
    D.vKnown[w]=30; // won't show for 30 cards
    delete D.vUnknown[w];
    D.xp+=3;toast('!מעולה 🌟','ok');
  } else {
    D.vUnknown[w]=8; // show again after 8 cards
    // Add to permanent unknown bank if not already there
    if(!D.uwBank.includes(w))D.uwBank.push(w);
    toast('תחזור אליה 💪','no');
  }
  sv();updUI();vi++;
  if(vi>=vPool.length){D.dd++;sv();updUI();toast('סיימת! 🎉','ok');vi=0;}
  showVC();
}
function flipC(){if(!revealed)revealV()} // clicking card also reveals

